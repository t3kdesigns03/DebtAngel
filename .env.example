# JCS Financial — environment variables
# Copy to .env.local and fill in when you connect a backend.

# Supabase (optional — for persisting application submissions later)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Scheduling link shown on the thank-you screen (e.g. Calendly)
NEXT_PUBLIC_SCHEDULING_URL=https://cal.com/jcs-financial/intro
