# Debt Angel — environment variables
# Copy to .env.local and fill in before running /apply submissions.

# Supabase (required for /apply — anonymous auth + RLS-backed persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Enable anonymous sign-in in Supabase Dashboard → Authentication → Providers → Anonymous

# Scheduling link shown on the thank-you screen (e.g. Cal.com)
NEXT_PUBLIC_SCHEDULING_URL=https://cal.com/debt-angel/intro

# Public site URL — used for magic-link redirects (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://mydebtangel.com

# ── Supabase Auth URL Configuration (dashboard, not env) ────────────────────
# Site URL:      https://mydebtangel.com
# Redirect URLs (add every origin you use):
#   - https://mydebtangel.com/auth/callback
#   - https://debtangel.t3kdesigns.app/auth/callback
#   - http://localhost:3000/auth/callback

# ── Custom SMTP (configured in Supabase dashboard, NOT read by the app) ──────
# These are documentation-only placeholders so on-brand auth emails send from
# your own domain instead of noreply@mail.app.supabase.io.
# Set them in Supabase → Project Settings → Authentication → SMTP Settings.
# See supabase/email-templates/README.md for the full setup + DNS checklist.
#   SMTP_SENDER_EMAIL=no-reply@mydebtangel.com
#   SMTP_SENDER_NAME=Debt Angel
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx   # provider API key — keep secret
